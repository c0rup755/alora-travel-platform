# Copy this file to .env and replace the placeholders with your keys
PORT=5000
########## Backend environment variables (Railway, etc.) ##########
# Replace the placeholder values with the real provider keys before deploying.
# Do NOT commit real keys to the repository. Use Railway / Vercel / GitHub Secrets.

AFFILIATE_ID=YOUR_AFFILIATE_ID_123
# Kiwi / Tequila API key (if using Kiwi)
KIWI_API_KEY=your_kiwi_api_key
# Skyscanner API key (if used)
SKY_API_KEY=your_skyscanner_api_key
# Booking/Expedia API key (if used)
BOOKING_API_KEY=your_booking_api_key

# Optional: set NODE_ENV=production for production services
# NODE_ENV=production

# Sentry (optional) - DSN for error reporting
SENTRY_DSN=
